{
    "name": "goldlapel/goldlapel-laravel",
    "description": "Laravel service provider for Gold Lapel — self-optimizing Postgres proxy",
    "type": "library",
    "license": "MIT",
    "repositories": [
        {
            "type": "path",
            "url": "../goldlapel-php"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "goldlapel/goldlapel": "*",
        "illuminate/support": ">=10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "GoldLapel\\Laravel\\": "src/"
        },
        "files": ["src/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "GoldLapel\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GoldLapel\\Laravel\\GoldLapelServiceProvider"
            ]
        }
    }
}
